int index = 0;

void setup()
{
  lcd.begin(16,2);
  Serial.begin(115200);
}

void printBinary(byte x)
{
  for(int b=7; b>=0; b--)
    lcd.print(bitRead(x,b));
}

void loop()
{
  if(index < sizeof(txData))
  {
    byte tx = txData[index];

    lcd.clear();

    lcd.setCursor(0,0);
    lcd.print("TX:");
    printBinary(tx);

    Serial.write(tx);

    while(!Serial.available());

    byte rx = Serial.read();

    lcd.setCursor(0,1);
    lcd.print("RX:");
    printBinary(rx);

    index++;

    //delay(10);
  }
}